{
  "mcpServers": {
    "hpo": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}/server",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/server/hpo_server.py"
      ]
    },
    "pubmed": {
      "command": "npx",
      "args": ["-y", "@cyanheads/pubmed-mcp-server"]
    }
  }
}
